# 复制为项目根目录下的 .env（已在 .gitignore，勿提交）
# 启动 cmd/api、cmd/importer 时会自动加载：自当前工作目录向上找到含 go.mod 的模块根，再加载 模块根/configs/.env（Load）与 模块根/.env（Overload）

# Milvus
MILVUS_PASSWORD=

# Elasticsearch（与 configs/api.yaml 中 elasticsearch 配合；enabled: true 时生效）
# ES_URL=http://10.12.111.133:19200
ES_USERNAME=
ES_PASSWORD=
# ES_INDEX=entity_postings_v1

# Query 多路重写（阿里云百炼 / DashScope OpenAI 兼容模式，见 internal/model/rewrite/chat.go）
# 启用后 POST /v1/search 会先调用 Chat 生成最多 5 条子查询，再并行 hybrid/milvus/es 召回并合并去重。
# REWRITE_ENABLED=true
# 与阿里云控制台一致；也可用 REWRITE_API_KEY
# DASHSCOPE_API_KEY=
# REWRITE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# REWRITE_MODEL=qwen-turbo
# REWRITE_TIMEOUT_SEC=60
# REWRITE_TEMPERATURE=0.3
# REWRITE_MAX_TOKENS=512

# 嵌入：仅两种方式，由 EMBEDDING_SOURCE 切换（Go 始终走 OpenAI 兼容 HTTP，见 internal/model/embedding/http_embedder.go）
#   remote       → 使用下方「远程」EMBEDDING_API_*（或 configs/api.yaml 里 embedding.endpoint）
#   self_hosted  → 使用 EMBEDDING_LOCAL_HTTP_* 拼 http://host:port/v1/embeddings（忽略 yaml 里远程 endpoint）
# 可选别名：remote 可用 api、cloud；self_hosted 可用 local_service、python
EMBEDDING_SOURCE=remote
# EMBEDDING_SOURCE=self_hosted

# --- 远程 OpenAI 兼容嵌入 API（EMBEDDING_SOURCE=remote 时）---
# EMBEDDING_API_BASE_URL=https://api.example.com
# EMBEDDING_API_KEY=
# EMBEDDING_API_MODEL=BAAI/bge-m3
# 任意模式下最高优先级：完整嵌入 URL（覆盖按 SOURCE 推导的地址）
# EMBEDDING_ENDPOINT=https://api.example.com/v1/embeddings

# --- 自建 python/embedding-service（EMBEDDING_SOURCE=self_hosted 时；与 demo_call_local.py 一致）---
# 填客户端要连的地址：本机请用 127.0.0.1（勿填 0.0.0.0，Windows 下 urllib/部分 HTTP 客户端会报错）
EMBEDDING_LOCAL_HTTP_HOST=127.0.0.1
EMBEDDING_LOCAL_HTTP_PORT=3888
# 本地自建嵌入：Go（self_hosted）与 python/embedding-service 可共用同一值；非空则双方都会要求/发送 Bearer（勿用 EMBEDDING_API_KEY）
# EMBEDDING_LOCAL_API_KEY=
# 若只想给 python 进程单独设鉴权、与上面分开时再设（优先于 EMBEDDING_LOCAL_API_KEY）
# EMBEDDING_SERVICE_API_KEY=
# 模型名仅两个：EMBEDDING_API_MODEL=远程 API 请求体 model；EMBEDDING_MODEL=自建 python 加载路径或 Hub id（Go self_hosted 发 HTTP 时也用同一变量，须与 Python 一致）
# EMBEDDING_API_MODEL=BAAI/bge-m3
# EMBEDDING_MODEL=BAAI/bge-m3
# 以下仅 embedding-service（Python）读取：
# EMBEDDING_LOADER=huggingface
# EMBEDDING_LOADER=sentence_transformers
# EMBEDDING_MODEL_KWARGS={"trust_remote_code":true,"torch_dtype":"bfloat16"}
# EMBEDDING_MAX_SEQ_LENGTH=2048
# EMBEDDING_DEVICE=auto
# EMBEDDING_MAX_BATCH=64
# EMBEDDING_TRUST_REMOTE_CODE=false
# EMBEDDING_STRICT_MODEL=true

# 入库队列（Redis）。以下二选一即可；均未配置时不会注册 POST /v1/admin/ingest 与 /ingest/remote
# A) 完整 URL（旧名 INGEST_QUEUE_REDIS_URL 仍可读）
# REDIS_INGEST_URL=redis://:yourpassword@127.0.0.1:6379/0
# B) Host + Port（可选密码 / 库号 / TLS；默认 port=6379、db=0）
# REDIS_INGEST_HOST=127.0.0.1
# REDIS_INGEST_PORT=6379
# REDIS_INGEST_PASSWORD=
# REDIS_INGEST_USERNAME=
# REDIS_INGEST_DB=0
# REDIS_INGEST_TLS=false
# REDIS_INGEST_ENABLED=true
# REDIS_INGEST_LIST_KEY=ingest:queue
# REDIS_INGEST_PAYLOAD_TTL_SEC=10800
# REDIS_INGEST_JOB_META_TTL_SEC=86400
# REDIS_INGEST_WORKER_CONCURRENCY=1

# S3（远程 ingest；Worker 只读）。凭证与 region 可走 AWS 标准环境变量 / IAM
# S3_ENDPOINT=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# 入库 Job/Task 元数据（MySQL + 独立 ES 索引；需先执行 migrations/001_ingest_job.sql）
# 配置了 MYSQL_DSN 时，cmd/api 与 importer worker 启动即初始化全局连接池并 Ping（与 INGEST_META_ENABLED 无关）。
# INGEST_META_ENABLED=true
# MYSQL_DSN=user:pass@tcp(127.0.0.1:3306)/agentic_search?parseTime=true&loc=UTC
# 无密码：省略「用户名:密码」中的密码与冒号，例如 root@tcp(127.0.0.1:3306)/agentic_search?parseTime=true&loc=UTC
# INGEST_ES_TASK_INDEX=agentic_search_ingest_task_v1

# 可选
# MILVUS_ADDRESS=
# MILVUS_USERNAME=
# MILVUS_DB_NAME=
# MILVUS_INDEX_TYPE=hnsw
# MILVUS_HNSW_M=16
# MILVUS_HNSW_EF_CONSTRUCTION=200
# MILVUS_HNSW_EF=64
# HTTP_ADDR=:8080
# API_CONFIG=configs/api.yaml
